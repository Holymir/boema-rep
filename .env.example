# ---- Resend (RFQ email delivery) ----
RESEND_API_KEY=
# Where RFQ submissions are sent (the company inbox)
RFQ_TO_EMAIL=office@metalparts.bg
# Verified sender domain/address in Resend
RFQ_FROM_EMAIL=website@metalparts.bg

# ---- Vercel Blob (RFQ drawing uploads) ----
BLOB_READ_WRITE_TOKEN=

# ---- Sanity CMS ----
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only read token (for previewing drafts; optional for public read)
SANITY_API_READ_TOKEN=

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://www.metalparts.bg
